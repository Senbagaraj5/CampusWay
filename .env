# Google Maps API Configuration
# Get your free API key from: https://cloud.google.com/maps/gmp-get-started

VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Note: Make sure these APIs are enabled in your Google Cloud Console:
# 1. Maps JavaScript API
# 2. Directions API
# 3. Distance Matrix API
# 4. Geolocation API (if using device geolocation)
